---
const { title, link, filename, span} = Astro.props;
---

<div
  class=`relative text-center col-span-1 ${span === "2" ? 'md:col-span-2' : 'md:col-span-1'} overflow-hidden transition-all duration-200 no-underline`
>
  <!-- card -->
  <div class="relative justify-center aspect-video overflow-hidden bg-(--bg)">
    <!-- thumb -->
    <video
      class="hover-play w-full h-full object-cover filter brightness-50 hover:brightness-100 transition-filter duration-300 ease-in-out"
      muted
      autoplay
      loop
    >
      <source src={`${filename}.mp4`} type="video/mp4" />
      Your browser does not support HTML5 video.
    </video>
  </div>
  <!-- overlay -->
  <div
    class="absolute inset-0 flex flex-col justify-end md:p-7 p-3 bg-linear-to-t from-0% from-(--bg) via-20% via-(--bg2) to-70% to-transparent"
  >
    <!-- title  -->
    <div
      class="text-(--text) text-left md:text-xl text-sm font-bold tracking-tight mb-2"
    >
      {title}
    </div>
    <!-- description -->
    <div class="text-(--muted2) text-left text-sm mb-4 max-w-100">
      <slot />
    </div>
    <!-- link -->
    <div class="text-(--accent) text-left text-xs md:text-sm">
      <a href={`/projects/${link}/`}
        >Read More...</a
      >
    </div>
  </div>
</div>
