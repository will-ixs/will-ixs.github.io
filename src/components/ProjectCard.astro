---
const { title, link, filename, span} = Astro.props;
---

<div
  class=`relative text-center ${span === "2" ? 'col-span-2' : 'col-span-1'} overflow-hidden transition-all duration-200 no-underline`
>
  <!-- card -->
  <div class="relative justify-center aspect-video overflow-hidden bg-(--bg)">
    <!-- thumb -->
    <video
      class="hover-play w-full h-full object-cover filter brightness-50 hover:brightness-100 transition-filter duration-300 ease-in-out"
      muted
      autoplay
      loop
    >
      <source src={`${filename}.mp4`} type="video/mp4" />
      Your browser does not support HTML5 video.
    </video>
  </div>
  <!-- overlay -->
  <div
    class="absolute inset-0 flex flex-col justify-end p-[28px] bg-gradient-to-t from-0% from-(--bg) via-20% via-(--bg2) to-70% to-transparent"
  >
    <!-- title  -->
    <div
      class="text-(--text) text-left text-xl font-bold tracking-tight mb-[8px]"
    >
      {title}
    </div>
    <!-- description -->
    <div class="text-(--muted2) text-left text-sm mb-[16px] max-w-[400px]">
      <slot />
    </div>
    <!-- link -->
    <div class="text-(--accent) text-left text-sm">
      <a href={`/projects/${link}/`}
        >Read More...</a
      >
    </div>
  </div>
</div>
